
GEMINI_API_KEY="votre-cle-gemini"

# URLs
APP_URL="http://localhost:3000"
SITE_URL="http://localhost:3000"


JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"

ADMIN_EMAIL="votre-email@example.com"

# ADMIN_PASSWORD : DOIT être un hash bcrypt (pas le mot de passe en clair)
# Générer le hash : node -e "require('bcryptjs').hash('votre_mdp', 12).then(console.log)"
# Exemple de hash pour 'monMotDePasse' : $2b$12$...
ADMIN_PASSWORD="$2b$12$hash-bcrypt-de-votre-mot-de-passe"

# ADMIN_PASSWORD_PLAIN : Mot de passe en clair pour le seed uniquement (utilisé par prisma/seed.ts)
# Changez-le après le premier seed!
ADMIN_PASSWORD_PLAIN="Admin@123"

# Database (Neon PostgreSQL pour Vercel)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Newsletter (Brevo)
BREVO_API_KEY="votre-cle-brevo"
BREVO_SENDER_EMAIL="noreply@votredomaine.com"
