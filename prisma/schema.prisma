// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url     = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  createdAt      DateTime @default(now())
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String   // video, model, ebook, note
  content     String
  status      String   @default("draft") // draft, published
  tags        String?  // Comma separated tags or subcategory for model
  description String?  // Description pour les ebooks et videos
  coverImage  String?  // URL de l'image de couverture
  downloadUrl String?  // Lien de telechargement (Google Drive)
  videoUrl    String?  // Lien de la video (YouTube / Drive)
  playlist    String?  // Nom de la playlist pour les videos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
